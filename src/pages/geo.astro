---
import BaseLayout from '../layouts/BaseLayout.astro';
import type { IndexFile } from '../lib/geo-types';

const INDEX_URL =
  'https://raw.githubusercontent.com/evanqhuang/geo-daemon/main/data/runs/index.json';

let data: IndexFile | null = null;
try {
  const res = await fetch(INDEX_URL);
  if (res.ok) data = await res.json();
} catch {
  data = null;
}

const fmt = (n: number) => `${(n * 100).toFixed(0)}%`;

const sortedCitations = data
  ? Object.entries(data.citations)
      .sort(([, a], [, b]) => b.count - a.count)
      .slice(0, 15)
  : [];
---

<BaseLayout title="GEO Experiment - Evan Huang" description="Tracking my visibility in AI-generated answers across ChatGPT, Claude, Gemini, and Google AI Overviews.">
  <section class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-[var(--spacing-section)]">
    <p class="section-label mb-2">Live Experiment</p>
    <h1 class="heading-page text-ash-100 text-balance mb-4">GEO</h1>
    <p class="text-body-lg text-ash-400 leading-body text-pretty max-w-[60ch] mb-12">
      Weekly cron queries four AI search engines with a fixed prompt set.
      Each result is parsed for whether "Evan Huang" is mentioned.
      Source: <a class="text-ember-400 hover:underline" href="https://github.com/evanqhuang/geo-daemon">github.com/evanqhuang/geo-daemon</a>.
    </p>

    {data === null && (
      <p class="text-ash-500 font-mono text-sm">No data yet — first run pending.</p>
    )}

    {data && (
      <>
        <!-- Headline stat -->
        <div class="card rounded-sm p-8 mb-12 relative overflow-hidden">
          <div class="absolute inset-0 dot-grid opacity-50"></div>
          <div class="relative">
            <p class="section-label mb-3">Share of Model</p>
            <p class="heading-display text-ember-400">{fmt(data.summary.share_of_model)}</p>
            <p class="text-mono-coord mt-3">last_updated: {data.last_updated.slice(0, 10)}</p>
          </div>
        </div>

        <!-- By engine -->
        <div class="mt-12 mb-6">
          <p class="section-label mb-1">Breakdown</p>
          <h2 class="heading-card text-ash-100">By Engine</h2>
        </div>
        <div class="card rounded-sm p-6 mb-12">
          <canvas id="byEngine" height="120"
            data-labels={JSON.stringify(Object.keys(data.summary.share_of_model_by_engine))}
            data-values={JSON.stringify(Object.values(data.summary.share_of_model_by_engine))}
          ></canvas>
        </div>

        <!-- Time series -->
        <div class="mt-12 mb-6">
          <p class="section-label mb-1">Trend</p>
          <h2 class="heading-card text-ash-100">Over Time</h2>
        </div>
        <div class="card rounded-sm p-6 mb-12">
          <canvas id="timeseries" height="160"
            data-labels={JSON.stringify(data.timeseries.map(p => p.run_id.slice(0, 10)))}
            data-values={JSON.stringify(data.timeseries.map(p => p.share_of_model))}
          ></canvas>
        </div>

        <!-- Citations -->
        <div class="mt-12 mb-6">
          <p class="section-label mb-1">Sources</p>
          <h2 class="heading-card text-ash-100">Top Citation Sources</h2>
        </div>
        <div class="card rounded-sm p-6 overflow-x-auto">
          <table class="w-full text-sm">
            <thead>
              <tr class="text-ash-500 text-left border-b border-[var(--surface-border)]">
                <th class="py-2 pr-4 font-mono text-xs uppercase tracking-widest">URL</th>
                <th class="py-2 text-right font-mono text-xs uppercase tracking-widest">Citations</th>
                <th class="py-2 text-right pl-4 font-mono text-xs uppercase tracking-widest">Owned</th>
              </tr>
            </thead>
            <tbody>
              {sortedCitations.map(([url, stat]) => (
                <tr class="border-b border-[var(--surface-border)] last:border-0">
                  <td class="py-2 pr-4 truncate max-w-md">
                    <a class="text-ash-300 hover:text-ember-400 transition-colors" href={url}>{url}</a>
                  </td>
                  <td class="py-2 text-right text-ash-300 font-mono">{stat.count}</td>
                  <td class="py-2 text-right pl-4">{stat.is_owned ? <span class="text-ember-400">✓</span> : ''}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>

        <script>
          import Chart from 'chart.js/auto';

          const css = getComputedStyle(document.documentElement);
          const EMBER = css.getPropertyValue('--accent-primary-hover').trim() || '#d97706';
          const EMBER_GLOW_RGB = css.getPropertyValue('--accent-glow-rgb').trim() || '217, 119, 6';
          const GRID = css.getPropertyValue('--surface-border').trim() || 'rgba(255,255,255,0.06)';
          const LABEL = css.getPropertyValue('--text-muted').trim() || '#9ca3af';

          const axisDefaults = {
            grid: { color: GRID },
            ticks: { color: LABEL, font: { family: 'IBM Plex Mono, monospace', size: 11 } },
          };

          const beEl = document.getElementById('byEngine') as HTMLCanvasElement;
          const beLabels = JSON.parse(beEl.dataset.labels!);
          const beValues = JSON.parse(beEl.dataset.values!);
          new Chart(beEl, {
            type: 'bar',
            data: {
              labels: beLabels,
              datasets: [{ data: beValues, backgroundColor: EMBER, borderRadius: 4 }],
            },
            options: {
              indexAxis: 'y',
              plugins: { legend: { display: false } },
              scales: {
                x: { ...axisDefaults, min: 0, max: 1, ticks: { ...axisDefaults.ticks, callback: (v: number) => (v * 100).toFixed(0) + '%' } },
                y: axisDefaults,
              },
            },
          });

          const tsEl = document.getElementById('timeseries') as HTMLCanvasElement;
          const tsLabels = JSON.parse(tsEl.dataset.labels!);
          const tsValues = JSON.parse(tsEl.dataset.values!);
          new Chart(tsEl, {
            type: 'line',
            data: {
              labels: tsLabels,
              datasets: [{
                data: tsValues,
                borderColor: EMBER,
                backgroundColor: `rgba(${EMBER_GLOW_RGB}, 0.1)`,
                fill: true,
                tension: 0.3,
                pointBackgroundColor: EMBER,
              }],
            },
            options: {
              plugins: { legend: { display: false } },
              scales: {
                x: axisDefaults,
                y: { ...axisDefaults, min: 0, max: 1, ticks: { ...axisDefaults.ticks, callback: (v: number) => (v * 100).toFixed(0) + '%' } },
              },
            },
          });
        </script>
      </>
    )}
  </section>
</BaseLayout>
