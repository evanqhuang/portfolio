---
const year = new Date().getFullYear();
---

<footer class="relative border-t border-[var(--surface-border)] mt-[var(--spacing-section)]">
  <!-- Ember gradient line -->
  <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-ember-500/40 to-transparent"></div>

  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-12 grid gap-10 md:grid-cols-2">
    <div>
      <p class="font-heading font-bold text-ash-100" style="font-size: var(--text-h3); letter-spacing: var(--tracking-heading);">
        Evan Huang
      </p>
      <p class="text-ash-400 mt-2 max-w-[40ch] leading-body">
        Embedded systems, quantitative trading, and developer tools.
      </p>
      <p class="text-mono-coord mt-6">© {year} — built with Astro</p>
    </div>

    <div class="md:justify-self-end space-y-3">
      <p class="section-label">Contact</p>
      <ul class="space-y-2">
        <li>
          <a
            class="font-mono text-sm text-ash-300 hover:text-ember-400 transition-colors"
            href="mailto:evanhuang117@gmail.com"
          >
            evanhuang117@gmail.com
          </a>
        </li>
        <li>
          <a
            class="font-mono text-sm text-ash-300 hover:text-ember-400 transition-colors"
            href="https://www.linkedin.com/in/evanqhuang"
            target="_blank"
            rel="noopener noreferrer"
          >
            linkedin.com/in/evanqhuang
          </a>
        </li>
        <li>
          <a
            class="font-mono text-sm text-ash-300 hover:text-ember-400 transition-colors"
            href="https://github.com/evanqhuang"
            target="_blank"
            rel="noopener noreferrer"
          >
            github.com/evanqhuang
          </a>
        </li>
      </ul>
    </div>
  </div>
</footer>
